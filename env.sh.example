#!/bin/bash
# ============================================================
# OncoTRAIL Environment Configuration (TEMPLATE)
# ============================================================
# Copy this file to env.sh and fill in your actual paths:
#   cp env.sh.example env.sh
# ============================================================

# --- Cluster SLURM Username ---
export CLUSTER_USERNAME="your_slurm_username"

# --- Project Root ---
# The parent directory containing your OncoTRAIL clone
export CLUSTER_ROOT_PREFIX="/path/to/your/gitrepo/2024"

# --- LLM Models Base Directory ---
# Directory containing downloaded LLM models
export LLM_BASE_DIR="/path/to/your/LLMs"

# --- Data Base Directory ---
# Directory containing clinical data
export DATA_BASE_DIR="/path/to/your/data"

# --- Physician Names Directory ---
# Directory containing phys_names.py for physician alias mappings
export PHYS_NAMES_DIR="/path/to/your/data/info"

# --- NLTK Data Directory ---
# Directory containing custom NLTK data resources
export NLTK_DATA_DIR="/path/to/your/LLMs/custom_nltk_data"
